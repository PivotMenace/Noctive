rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.uid in [
          "TljwjuBuKvd6VG9e0Mz81y7ZRgi1",
          "G6RyacKuSUTLXniBWRC1WsAm4Rq2"
        ];
    }

    function isReservedUsername(username) {
      return username in [
        "noctive",
        "noctivehq",
        "noctiveofficial",
        "noctivestaff",
        "noctiveadmin",
        "venus"
      ];
    }

    function isVoteOnlyPostUpdate() {
      return isSignedIn()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "votes",
          "likesCount"
        ]);
    }

    match /Posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0;
      allow update: if isSignedIn()
        && (
          (
            request.auth.uid == resource.data.uid
            && request.resource.data.uid == resource.data.uid
          )
          || isVoteOnlyPostUpdate()
        );
      allow delete: if isAdmin()
        || (isSignedIn() && request.auth.uid == resource.data.uid);

      match /Votes/{userId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.direction in ["up", "down"];
        allow delete: if isOwner(userId);
      }

      match /Comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 500;
        allow update: if false;
        allow delete: if isAdmin()
          || (isSignedIn() && request.auth.uid == resource.data.uid);
      }
    }

    match /Profiles/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /Usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == username
        && !exists(/databases/$(database)/documents/Usernames/$(username))
        && (
          !isReservedUsername(username)
          || isAdmin()
        );
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
